# ============================================================================
# IPFS Storage Configuration
# ============================================================================

# IPFS node URL (required) - e.g. https://ipfs.infura.io:5001, http://localhost:5001
IPFS_HOST=http://localhost:5001
IPFS_PORT=5001
IPFS_PROTOCOL=http

# Optional: IPFS authentication (for managed providers like Infura/Pinata)
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=

# Optional: IPFS gateway for reading content (defaults to https://ipfs.io)
IPFS_GATEWAY_URL=https://ipfs.io

# ============================================================================
# Image Optimization
# ============================================================================

# Maximum image dimensions for optimization (pixels)
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048

# Image quality for JPEG/WebP optimization (1-100)
IMAGE_QUALITY=80

# Allowed image MIME types (comma-separated)
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ============================================================================
# Storage Limits
# ============================================================================

# Maximum file size for uploads in bytes (default: 100MB matching on-chain contract)
MAX_FILE_SIZE=104857600

# Maximum total pinned size per property in bytes (default: 500MB matching on-chain contract)
MAX_PINNED_SIZE_PER_PROPERTY=524288000

# ============================================================================
# Stellar / Soroban Contract Integration
# ============================================================================

# Stellar network passphrase
STELLAR_NETWORK=TESTNET

# IPFS metadata contract ID on Soroban
IPFS_METADATA_CONTRACT_ID=

# Soroban RPC URL
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ============================================================================
# Application
# ============================================================================

# Server port
PORT=3000

# Log level: debug, verbose, log, warn, error
LOG_LEVEL=log
